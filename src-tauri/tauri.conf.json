{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "maki",
  "version": "0.1.0",
  "identifier": "dev.maki.Maki",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Shiori",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$CACHE/maki/covers/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "category": "Reference",
    "shortDescription": "A beautiful, fast ebook reader for Linux",
    "longDescription": "Shiori is a modern ebook reader for Linux supporting EPUB, MOBI, AZW3, FB2, CBZ and PDF, with annotations, reading progress, and a carefully designed reading experience.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
