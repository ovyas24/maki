# Maintainer: Maki contributors <https://github.com/ovyas24/maki>
#
# Publishing to the AUR:
#   Easiest — run the helper (after the GitHub release for the version exists):
#       packaging/aur/publish.sh 0.3.0
#   It clones the AUR repo, fills sha256sums, regenerates .SRCINFO, test-builds,
#   and pushes.
#
#   One-time prerequisite: an AUR account with your SSH public key added
#   (https://aur.archlinux.org → My Account → SSH Public Key).
#
#   Manual equivalent:
#     git clone ssh://aur@aur.archlinux.org/maki.git aur-maki && cd aur-maki
#     cp /path/to/maki/packaging/aur/PKGBUILD .
#     updpkgsums                        # fills in real sha256sums
#     makepkg --printsrcinfo > .SRCINFO
#     makepkg -si                       # test build + install locally
#     namcap PKGBUILD maki-*.pkg.tar.zst
#     git add PKGBUILD .SRCINFO && git commit -m "v$pkgver" && git push

pkgname=maki
pkgver=0.3.0
pkgrel=1
pkgdesc="A beautiful, fast ebook reader for Linux"
arch=(x86_64)
url="https://github.com/ovyas24/maki"
license=(GPL-3.0-or-later)
depends=(webkit2gtk-4.1 gtk3 libsoup3 glib2 cairo gdk-pixbuf2 pango hicolor-icon-theme)
makedepends=(rust nodejs pnpm)
# Cargo does its own LTO (see [profile.release] in Cargo.toml). Disable makepkg's
# C-level LTO: it injects -flto into CFLAGS, so the cc crate compiles rusqlite's
# bundled sqlite3.c to GCC LTO bitcode that rust's lld linker can't resolve
# (undefined sqlite3_* symbols). Required when makepkg.conf enables the `lto`
# option (default on e.g. CachyOS).
options=(!lto)
source=("$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz")
sha256sums=('SKIP') # run `updpkgsums` after each release tag

prepare() {
  cd "$pkgname-$pkgver"
  export PNPM_HOME="$srcdir/pnpm-home"
  pnpm config set store-dir "$srcdir/pnpm-store"
  pnpm install --frozen-lockfile
}

build() {
  cd "$pkgname-$pkgver"
  pnpm config set store-dir "$srcdir/pnpm-store"
  # builds the frontend (beforeBuildCommand) and the release binary; no bundles
  pnpm tauri build --no-bundle
}

package() {
  cd "$pkgname-$pkgver"
  install -Dm755 "src-tauri/target/release/$pkgname" "$pkgdir/usr/bin/$pkgname"
  install -Dm644 packaging/maki.desktop "$pkgdir/usr/share/applications/$pkgname.desktop"
  for size in 32 128 256 512; do
    install -Dm644 "src-tauri/icons/${size}x${size}.png" \
      "$pkgdir/usr/share/icons/hicolor/${size}x${size}/apps/$pkgname.png"
  done
  install -Dm644 src-tauri/icons/icon.svg \
    "$pkgdir/usr/share/icons/hicolor/scalable/apps/$pkgname.svg"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
