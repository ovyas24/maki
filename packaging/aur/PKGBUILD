# Maintainer: Shiori contributors <https://github.com/ovyas24/shiori>
#
# Publishing to the AUR (one-time setup + per release):
#   1. Create an AUR account at https://aur.archlinux.org and add your SSH key
#      (Account → SSH Public Key).
#   2. git clone ssh://aur@aur.archlinux.org/shiori.git aur-shiori
#   3. Copy this PKGBUILD into it, bump pkgver, then:
#        updpkgsums                      # fills in real sha256sums
#        makepkg --printsrcinfo > .SRCINFO
#        makepkg -si                     # test build + install locally
#        namcap PKGBUILD shiori-*.pkg.tar.zst   # lint before pushing
#   4. git add PKGBUILD .SRCINFO && git commit -m "v$pkgver" && git push
#      (pushing to aur.archlinux.org publishes immediately)

pkgname=shiori
pkgver=0.1.0
pkgrel=1
pkgdesc="A beautiful, fast ebook reader for Linux"
arch=(x86_64)
url="https://github.com/ovyas24/shiori"
license=(GPL-3.0-or-later)
depends=(webkit2gtk-4.1 gtk3 libsoup3 glib2 cairo gdk-pixbuf2 pango hicolor-icon-theme)
makedepends=(rust nodejs pnpm)
source=("$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz")
sha256sums=('SKIP') # run `updpkgsums` after each release tag

prepare() {
  cd "$pkgname-$pkgver"
  export PNPM_HOME="$srcdir/pnpm-home"
  pnpm config set store-dir "$srcdir/pnpm-store"
  pnpm install --frozen-lockfile
}

build() {
  cd "$pkgname-$pkgver"
  pnpm config set store-dir "$srcdir/pnpm-store"
  # builds the frontend (beforeBuildCommand) and the release binary; no bundles
  pnpm tauri build --no-bundle
}

package() {
  cd "$pkgname-$pkgver"
  install -Dm755 "src-tauri/target/release/$pkgname" "$pkgdir/usr/bin/$pkgname"
  install -Dm644 packaging/shiori.desktop "$pkgdir/usr/share/applications/$pkgname.desktop"
  for size in 32 128 256 512; do
    install -Dm644 "src-tauri/icons/${size}x${size}.png" \
      "$pkgdir/usr/share/icons/hicolor/${size}x${size}/apps/$pkgname.png"
  done
  install -Dm644 src-tauri/icons/icon.svg \
    "$pkgdir/usr/share/icons/hicolor/scalable/apps/$pkgname.svg"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
